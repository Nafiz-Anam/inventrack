# Use Node.js LTS (non-Alpine for better Prisma compatibility)
FROM node:22-slim

# Install OpenSSL and other dependencies for Prisma
RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

# Create app directory
WORKDIR /usr/src/app

# Install pnpm
RUN npm install -g pnpm

# Copy package file
COPY package.json pnpm-lock.yaml* ./

# Copy Prisma schema first (needed for Prisma client generation)
COPY prisma ./prisma
COPY prisma.config.ts ./

# Install dependencies
RUN pnpm install

# Generate Prisma Client (provide dummy DATABASE_URL for build-time generation)
RUN DATABASE_URL="postgresql://dummy:dummy@localhost:5432/dummy" npx prisma generate

# Copy source code
COPY . .

# Make entrypoint executable
RUN chmod +x docker-entrypoint.sh

# Expose the app port
EXPOSE 8000

# Start with entrypoint that handles migrations + seeding
CMD ["./docker-entrypoint.sh"]

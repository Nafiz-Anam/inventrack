# ═══════════════════════════════════════════════════
# InvenTrack - Production Environment Files
# These are created automatically by CI/CD on first deploy.
# To create manually, place them in ~/inventrack/
# ═══════════════════════════════════════════════════

# ── docker-compose .env (root) ──
# File: ~/inventrack/.env
DOCKERHUB_USERNAME=your_dockerhub_username
POSTGRES_PASSWORD=generate_with_openssl_rand_hex_32

# ── server.env ──
# File: ~/inventrack/server.env
NODE_ENV=production
PORT=8000
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@postgres:5432/inventrackdb?schema=public
JWT_SECRET=generate_with_openssl_rand_hex_64
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@inventrack.com
CLIENT_URL=https://inventrack.agiloit.store

# ── client.env ──
# File: ~/inventrack/client.env
NODE_ENV=production
HOSTNAME=0.0.0.0
NEXT_PUBLIC_API_URL=https://api.inventrack.agiloit.store/v1
